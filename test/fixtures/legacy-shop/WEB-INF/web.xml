<?xml version="1.0"?>
<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN" "http://java.sun.com/dtd/web-app_2_3.dtd">
<web-app>
  <servlet>
    <servlet-name>legacyReport</servlet-name>
    <servlet-class>com.acme.web.LegacyReportServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>legacyReport</servlet-name>
    <url-pattern>/report/export.do</url-pattern>
  </servlet-mapping>
  <servlet>
    <servlet-name>apiServlet</servlet-name>
    <servlet-class>com.acme.api.ApiServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>apiServlet</servlet-name>
    <url-pattern>/api/*</url-pattern>
  </servlet-mapping>
</web-app>
