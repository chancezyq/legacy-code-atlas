<?xml version="1.0"?>
<!DOCTYPE struts-config PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 1.3//EN" "http://struts.apache.org/dtds/struts-config_1_3.dtd">
<struts-config>
  <action-mappings>
    <action path="/order/audit"
            type="com.acme.order.web.OrderAuditAction"
            name="orderAuditForm"
            parameter="method">
      <forward name="success" path="/order/auditSuccess.jsp" />
      <forward name="error" path="/order/audit.jsp" />
    </action>
  </action-mappings>
</struts-config>
